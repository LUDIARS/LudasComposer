# =============================================================================
# Ars Secrets Configuration
#
# このファイルを secrets.toml にコピーして値を設定してください。
#   cp secrets.toml.example secrets.toml
#
# 配置場所（優先順位順）:
#   1. カレントディレクトリ ./secrets.toml
#   2. ~/.config/ars/secrets.toml
#
# ⚠ secrets.toml には認証情報が含まれるため、絶対にコミットしないでください。
#
# Docker Compose の場合:
#   1. このファイルを secrets.toml にコピー
#   2. AWS SSM の場合は .env に AWS 認証情報を設定:
#        AWS_ACCESS_KEY_ID=<your-access-key>
#        AWS_SECRET_ACCESS_KEY=<your-secret-key>
#        AWS_REGION=ap-northeast-1
#   3. docker compose up -d
# =============================================================================

# プロバイダー選択: "aws-ssm" または "infisical"
provider = "aws-ssm"

# =============================================================================
# AWS SSM Parameter Store (provider = "aws-ssm" の場合)
#
# AWS認証情報は環境変数またはIAMロールから取得されます：
#   AWS_ACCESS_KEY_ID     — AWSアクセスキーID
#   AWS_SECRET_ACCESS_KEY — AWSシークレットアクセスキー
#   AWS_REGION            — AWSリージョン (例: ap-northeast-1)
#
# 以下のSSMパラメータを作成してください：
#   /ars/shared/GITHUB_CLIENT_ID
#   /ars/shared/GITHUB_CLIENT_SECRET
#   /ars/shared/GITHUB_REDIRECT_URI
#   /ars/shared/REDIS_URL
#   /ars/shared/SURREALDB_DATA_DIR
# =============================================================================
[aws_ssm]
# AWSリージョン（省略時は AWS_REGION 環境変数を使用）
# region = "ap-northeast-1"

# SSMパラメータ名のプレフィックス
path_prefix = "/ars"

# シークレットパス
shared_path = "/shared"
personal_path_prefix = "/personal"

# キャッシュTTL（秒）
cache_ttl_secs = 300

# =============================================================================
# Infisical (provider = "infisical" の場合)
#
# Infisical Dashboard > Project Settings > Machine Identities で
# Universal Auth の Machine Identity を作成してください。
# =============================================================================
# [infisical]
# host = "https://app.infisical.com"
# client_id = ""
# client_secret = ""
# project_id = ""
# environment = "dev"
# shared_path = "/shared"
# personal_path_prefix = "/personal"
# cache_ttl_secs = 300
